<?xml version="1.0" encoding="UTF-8" ?>
<included>
    <include resource="org/springframework/boot/logging/logback/defaults.xml" />

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%clr(%d{HH:mm:ss.SSS}){faint} %clr(%5level){highlight} %clr([%X{traceId:-}]){cyan} %clr([%X{method:-} %X{requestUri:-}]){blue} %clr([userId=%X{userId:-}]){magenta} %clr(%-40.40logger{39}){cyan} %clr(:){faint} %msg%n</pattern>
        </encoder>
    </appender>
</included>
